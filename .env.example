# 本地运行配置（勿提交真实密钥到 Git）

# mock | real — 默认 mock，不调用真实微信 API
WECHAT_MODE=mock

# 公众号 AppID / Secret（仅 WECHAT_MODE=real 时需要，从环境变量读取，勿写入日志）
WECHAT_APP_ID=
WECHAT_APP_SECRET=

# 封面图路径（相对项目根；real 模式 draft/add 需要 thumb_media_id；留空则使用内置占位图）
WECHAT_DEFAULT_THUMB_PATH=assets/default_thumb.png

# real 模式是否调用 freepublish/submit（false 则只创建草稿）
WECHAT_ENABLE_PUBLISH=false

# 调度：计划窗口与轮询间隔（秒）
SCHEDULE_WINDOW_DAYS=7
SCHEDULER_POLL_SECONDS=60
MAX_ARTICLES_PER_DAY=2

# 任务失败重试上限（retry-failed 会重置计数）
MAX_JOB_RETRIES=3

# DRY_RUN=true 时 run-once/scheduler 只写报告，不调用适配器
DRY_RUN=false

# 数据库与路径（相对项目根目录）
DATABASE_PATH=data/app.sqlite3
ARTICLES_INBOX=articles/inbox
RULES_PATH=config/rules.yaml

# 日志（LOG_FILE=none 关闭文件日志）
LOG_FILE=data/logs/app.log
LOG_MAX_BYTES=1048576
LOG_BACKUP_COUNT=3
LOG_LEVEL=INFO

# Web 管理后台（wechat-scheduler serve）
WEB_HOST=127.0.0.1
WEB_PORT=8080
# 到点自动执行：仅处理任务上勾选了 auto_execute 的项
WEB_AUTO_RUN_DUE=true
# 真实发布模式下是否允许 Web 后台到点自动提交 freepublish（仍须任务级 publish_action=publish）
WEB_AUTO_PUBLISH=true

# 安全：禁止在日志中打印 token
LOG_REDACT_SECRETS=true

# manual_export 通用 outbox 导出目录（Web「导出」按钮；与外部 Agent 任务包目录分开配置）
MANUAL_EXPORT_OUTBOX=outbox

# External Browser Agent Integration
EXTERNAL_AGENT_TASK_EXPORT_ENABLED=true
EXTERNAL_AGENT_TASK_OUTBOX=outbox/wechat_agent_tasks
EXTERNAL_AGENT_INCLUDE_ARTICLE_PREVIEW=true
EXTERNAL_AGENT_INCLUDE_COVER=true
EXTERNAL_AGENT_INCLUDE_PROMPT=true
# This project does not run browser agent internally by default
INTERNAL_BROWSER_AGENT_ENABLED=false
INTERNAL_LLM_AGENT_ENABLED=false

# Auto-Approved Pipeline（Round 55；仅 pipeline 元数据，非公众号后台审核）
# 默认 auto：真实 API 样本标记 review_status=auto_approved，不等待人工
AUTO_APPROVE_GENERATIONS=true
REVIEW_MODE=auto
# 切回人工元数据模式：
# AUTO_APPROVE_GENERATIONS=false
# REVIEW_MODE=manual
# SKIP_HUMAN_REVIEW=true
